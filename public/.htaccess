# Server Manager — Apache rewrite rules
# Assumes DocumentRoot points at this public/ directory.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route /api/* into the API front controller with ?r=<path>.
    RewriteRule ^api/?$ api/index.php [L]
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^api/(.*)$ api/index.php?r=$1 [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Never serve dotfiles or config
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
